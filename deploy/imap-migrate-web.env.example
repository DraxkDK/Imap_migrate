# Environment for the IMAP Migration web UI.
# Copy to /etc/imap-migrate-web.env, fill in real values, then:
#   sudo chown root:imapmig /etc/imap-migrate-web.env
#   sudo chmod 640 /etc/imap-migrate-web.env

# REQUIRED — master secret. Generate once with:
#   python manage_web.py gen-secret
# Signs sessions AND derives the key that encrypts stored IMAP passwords.
# Losing it = stored passwords unrecoverable. Leaking it = passwords compromised.
IMAP_WEB_SECRET_KEY=CHANGE_ME_to_a_long_random_value

# Running behind a TLS-terminating reverse proxy (Nginx/Caddy). Keep =1 in prod:
# enables ProxyFix and the Secure flag on session cookies.
IMAP_WEB_BEHIND_PROXY=1

# Storage locations (writable by the service account):
IMAP_WEB_DB=/opt/imap-migrate/web_app.db
IMAP_WEB_STATE_DB=/opt/imap-migrate/migration_state.db
IMAP_WEB_LOG_DIR=/opt/imap-migrate/logs
IMAP_WEB_REPORT_DIR=/opt/imap-migrate/reports

# Default IMAP servers (can be overridden per-account in the UI):
IMAP_SOURCE_HOST=mail.old-domain.com
IMAP_SOURCE_PORT=993
IMAP_TARGET_HOST=mail.new-domain.com
IMAP_TARGET_PORT=993

# Engine tuning:
IMAP_WEB_MAX_WORKERS=20

# NEVER set this to 1 in production — it disables TLS certificate verification
# to the mail servers:
IMAP_WEB_ALLOW_INSECURE_CERT=0
