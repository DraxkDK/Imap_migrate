@{
    ViewData["Title"] = "Two-factor (MFA)";
    var enabled = (bool)(ViewBag.Enabled ?? false);
}

<div class="card" style="max-width: 520px;">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Xác thực 2 lớp (MFA)</span>
        @if (enabled)
        {
            <span class="badge bg-success">Đang BẬT</span>
        }
        else
        {
            <span class="badge bg-secondary">Đang TẮT</span>
        }
    </div>
    <div class="card-body">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success py-2 small">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger py-2 small">@TempData["Error"]</div>
        }
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2 small">
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@e.ErrorMessage</div>
                }
            </div>
        }

        @if (!enabled)
        {
            <p class="small text-muted mb-2">
                1. Mở app <strong>Google Authenticator</strong> / <strong>Microsoft Authenticator</strong> →
                quét mã QR bên dưới.<br />
                2. Nhập mã 6 số app hiển thị để xác nhận.
            </p>
            <div class="text-center mb-3">
                <img src="@ViewBag.QrDataUri" alt="MFA QR" style="width:200px;height:200px;" />
            </div>
            <p class="small text-muted">
                Không quét được? Nhập tay khoá này vào app:<br />
                <code style="font-size:13px;">@ViewBag.Secret</code>
            </p>
            <form method="post" asp-action="Mfa" class="mt-3">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label small">Mã xác thực (6 số)</label>
                    <input name="code" class="form-control" inputmode="numeric" pattern="[0-9]*"
                           maxlength="6" autocomplete="one-time-code" autofocus required style="letter-spacing:.3em;" />
                </div>
                <button type="submit" class="btn btn-primary">Bật MFA</button>
            </form>
        }
        else
        {
            <p class="small text-muted">
                Tài khoản này đang yêu cầu mã từ app mỗi lần đăng nhập. Để tắt, nhập mã hiện tại rồi bấm Tắt MFA.
            </p>
            <form method="post" asp-action="DisableMfa" onsubmit="return confirm('Tắt MFA cho tài khoản này?');">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label small">Mã xác thực (6 số)</label>
                    <input name="code" class="form-control" inputmode="numeric" pattern="[0-9]*"
                           maxlength="6" autocomplete="one-time-code" required style="letter-spacing:.3em;max-width:200px;" />
                </div>
                <button type="submit" class="btn btn-outline-danger">Tắt MFA</button>
            </form>
        }
    </div>
</div>
