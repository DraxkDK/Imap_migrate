@{
    ViewData["Title"] = "Agent Installer";
    var selectedBatch = ViewBag.SelectedBatch as DKS.Migration.Portal.Models.MigrationBatch;
    var activeToken = ViewBag.ActiveToken as DKS.Migration.Portal.Models.AgentToken;
    var baseUrl = ViewBag.BaseUrl as string ?? "";
    var modeValue = ViewBag.ModeValue as string ?? "EXPORT_RECONFIG_IMPORT";
    var standaloneExePath = ViewBag.StandaloneExePath as string;
    var standaloneExeReady = !string.IsNullOrWhiteSpace(standaloneExePath);
}

<div class="row g-3">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">Select Batch</div>
            <div class="card-body">
                <form method="get">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Migration Batch</label>
                        <select name="batchId" class="form-select" onchange="this.form.submit()">
                            <option value="">-- Select batch --</option>
                            @foreach (var item in (ViewBag.Batches as Microsoft.AspNetCore.Mvc.Rendering.SelectList ?? new Microsoft.AspNetCore.Mvc.Rendering.SelectList(new object[0])))
                            {
                                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                            }
                        </select>
                    </div>
                </form>

                @if (selectedBatch != null)
                {
                    <dl class="small mb-0">
                        <dt class="text-muted">Customer</dt><dd>@selectedBatch.Customer?.CustomerName</dd>
                        <dt class="text-muted">Mode</dt><dd>@selectedBatch.Mode</dd>
                        <dt class="text-muted">Active Token</dt>
                        <dd>
                            @if (activeToken != null)
                            {
                                <code class="small">@activeToken.Token[..16]...</code>
                                <span class="badge bg-success ms-1">Active</span>
                            }
                            else
                            {
                                <span class="text-danger">No token</span>
                            }
                        </dd>
                    </dl>
                    <form asp-action="GenerateToken" method="post" class="mt-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="batchId" value="@selectedBatch.BatchId" />
                        <button class="btn btn-sm btn-outline-warning w-100">&#128273; Generate New Token</button>
                    </form>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8">
        @if (selectedBatch != null && activeToken != null)
        {
            <div class="card mb-3">
                <div class="card-header">MSI Install Command</div>
                <div class="card-body">
                    <pre id="msiCommand" class="bg-dark text-light p-3 rounded small mb-2">msiexec /i DKSProfileAgent.msi /qn ^
  APIURL="@baseUrl/api/agent" ^
  CUSTOMERCODE="@selectedBatch.Customer?.CustomerCode" ^
  AGENTTOKEN="@activeToken.Token" ^
  MODE="@modeValue" ^
  LOGPATH="C:\ProgramData\DKS\ProfileAgent\Logs" ^
  AUTOSTART="true"</pre>
                    <button class="btn btn-sm btn-outline-secondary" onclick="copyCmd()">&#128203; Copy</button>
                    <script>
                    function copyCmd() {
                        var pre = document.getElementById('msiCommand');
                        navigator.clipboard.writeText(pre.innerText);
                        alert('Copied to clipboard!');
                    }
                    </script>
                </div>
            </div>
            <div class="card">
                <div class="card-header">Download Options</div>
                <div class="card-body">
                    <div class="d-flex gap-2 flex-wrap">
                        @if (standaloneExeReady)
                        {
                            <a asp-action="DownloadExePackage" asp-route-batchId="@selectedBatch.BatchId" class="btn btn-success">&#11015; Download EXE Package (.zip)</a>
                        }
                        else
                        {
                            <span class="btn btn-success disabled">&#11015; Download EXE Package (.zip)</span>
                        }
                        <a asp-action="DownloadMsi" class="btn btn-primary">&#11015; Download MSI</a>
                        <a asp-action="DownloadGpoScript" asp-route-batchId="@selectedBatch.BatchId" class="btn btn-outline-secondary">&#11015; GPO Script (.ps1)</a>
                        <a asp-action="DownloadIntuneScript" asp-route-batchId="@selectedBatch.BatchId" class="btn btn-outline-secondary">&#11015; Intune Script (.ps1)</a>
                    </div>

                    @if (standaloneExeReady)
                    {
                        <div class="alert alert-success mt-3 mb-0">
                            Standalone EXE packaging is ready. The ZIP will contain <code>DKSProfileAgent.exe</code>, <code>appsettings.json</code>, and a short <code>README.txt</code>.
                            <div class="small text-muted mt-1">Source EXE: @standaloneExePath</div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mt-3 mb-0">
                            Standalone EXE packaging is not ready yet. Build or copy <code>DKSProfileAgent.exe</code> into <code>wwwroot/agent/</code>, or set <code>AgentPackage:StandaloneExePath</code>.
                        </div>
                    }
                </div>
            </div>
        }
        else if (selectedBatch != null)
        {
            <div class="alert alert-warning">Generate a token first to get the install command.</div>
        }
        else
        {
            <div class="alert alert-info">Select a migration batch to get the agent installer and install command.</div>
        }
    </div>
</div>

<div class="card mt-3">
    <div class="card-header">Agent Workflow</div>
    <div class="card-body">
        <div class="d-flex gap-0 flex-wrap">
            @{
                var steps = new[]{ "Register Device","Detect Outlook","Scan Profiles","Detect POP3 Account","Find PST Files","Export PST to Backup","Backup Profile (Registry)","Create New Profile","Add M365 / Autodiscover","Import PST","Report Complete" };
                for (int i = 0; i < steps.Length; i++) {
                    <div class="d-flex align-items-center">
                        <div class="bg-primary text-white rounded-pill px-3 py-1 small text-nowrap">@(i+1). @steps[i]</div>
                        @if (i < steps.Length - 1) { <span class="mx-1 text-muted">→</span> }
                    </div>
                }
            }
        </div>
    </div>
</div>
