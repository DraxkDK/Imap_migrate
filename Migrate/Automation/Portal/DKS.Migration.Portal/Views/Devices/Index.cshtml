@model IEnumerable<DKS.Migration.Portal.Models.Device>
@{ ViewData["Title"] = "Devices"; }

<form method="post" asp-action="ImportToM365">
@Html.AntiForgeryToken()
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div class="d-flex gap-2 align-items-center">
            <span>Devices</span>
            <button type="submit" class="btn btn-sm btn-success"
                    onclick="return confirm('Import the selected device(s) PST to Microsoft 365 via Graph? Agents run it on next check-in.');">
                &#9729; Import selected to M365
            </button>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <select name="status" form="filterForm" class="form-select form-select-sm" onchange="document.getElementById('filterForm').submit()">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetNames(typeof(DKS.Migration.Portal.Models.DeviceStatus)))
                {
                    <option value="@s" selected="@(ViewBag.Status == s)">@s</option>
                }
            </select>
        </div>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead><tr>
                <th style="width:32px"><input type="checkbox" onclick="document.querySelectorAll('.dev-chk').forEach(c=>c.checked=this.checked)" /></th>
                <th>Computer</th><th>User</th><th>Batch</th><th>Outlook</th><th>PST Count</th><th>Status</th><th>Progress</th><th>Last Check-in</th><th>Error</th><th></th>
            </tr></thead>
            <tbody>
            @foreach (var d in Model)
            {
                var sCls = d.CurrentStatus == DKS.Migration.Portal.Models.DeviceStatus.Completed ? "bg-success" :
                           d.CurrentStatus == DKS.Migration.Portal.Models.DeviceStatus.Failed ? "bg-danger" :
                           d.CurrentStatus == DKS.Migration.Portal.Models.DeviceStatus.NeedManualAction ? "bg-warning text-dark" :
                           d.CurrentStatus == DKS.Migration.Portal.Models.DeviceStatus.AgentOnline ? "bg-info" :
                           d.CurrentStatus == DKS.Migration.Portal.Models.DeviceStatus.Pending ? "bg-light text-dark border" : "bg-secondary";
                <tr>
                    <td><input class="dev-chk" type="checkbox" name="ids" value="@d.DeviceId" /></td>
                    <td><a asp-action="Details" asp-route-id="@d.DeviceId"><strong>@d.ComputerName</strong></a></td>
                    <td class="text-muted">@d.WindowsUsername</td>
                    <td><a asp-controller="Batches" asp-action="Details" asp-route-id="@d.BatchId" class="small">@d.Batch?.Customer?.CustomerCode</a></td>
                    <td class="small">@d.OutlookVersion</td>
                    <td><span class="badge bg-light text-dark border">@d.PstCount</span></td>
                    <td><span class="badge @sCls" style="font-size:11px">@d.CurrentStatus</span></td>
                    <td style="min-width:150px">
                        <div id="prog-@d.DeviceId" class="progress" style="height:15px;@(d.ImportPercent.HasValue ? "" : "display:none")">
                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-info" role="progressbar"
                                 style="width:@(d.ImportPercent ?? 0)%; font-size:10px;">@(d.ImportPercent ?? 0)%</div>
                        </div>
                        <div id="progtext-@d.DeviceId" class="text-muted text-truncate" style="font-size:10px;max-width:150px" title="@d.ImportStatusText">@d.ImportStatusText</div>
                    </td>
                    <td class="text-muted small text-nowrap">@d.LastCheckIn?.ToString("MM-dd HH:mm")</td>
                    <td class="text-danger small text-truncate" style="max-width:150px" title="@d.ErrorMessage">@d.ErrorMessage</td>
                    <td><a asp-action="Details" asp-route-id="@d.DeviceId" class="btn btn-xs btn-outline-secondary">Detail</a></td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="11" class="text-center text-muted py-4">No devices found. Install the agent on user machines.</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
</form>

@* Status filter (separate GET form so it doesn't submit the bulk selection). *@
<form id="filterForm" method="get">
    @if (ViewBag.BatchId != null) { <input type="hidden" name="batchId" value="@ViewBag.BatchId" /> }
</form>

@* Live progress: poll every 4s and update each device's bar without a full reload. *@
<script>
    (function () {
        var url = '@Url.Action("ProgressJson")' + (@(ViewBag.BatchId != null ? "true" : "false") ? '?batchId=@ViewBag.BatchId' : '');
        async function tick() {
            try {
                var r = await fetch(url, { headers: { 'X-Requested-With': 'fetch' } });
                if (!r.ok) return;
                var list = await r.json();
                list.forEach(function (d) {
                    var wrap = document.getElementById('prog-' + d.id);
                    var txt = document.getElementById('progtext-' + d.id);
                    if (!wrap) return;
                    if (d.percent === null || d.percent === undefined) { wrap.style.display = 'none'; if (txt) txt.textContent = ''; return; }
                    wrap.style.display = '';
                    var bar = wrap.querySelector('.progress-bar');
                    bar.style.width = d.percent + '%';
                    bar.textContent = d.percent + '%';
                    if (d.percent >= 100) { bar.classList.remove('progress-bar-animated'); bar.classList.remove('bg-info'); bar.classList.add('bg-success'); }
                    if (txt) { txt.textContent = d.text || ''; txt.title = d.text || ''; }
                });
            } catch (e) { /* ignore */ }
        }
        setInterval(tick, 4000);
        tick();
    })();
</script>
