@{ ViewData["Title"] = "Import Users CSV"; var batch = ViewBag.Batch as DKS.Migration.Portal.Models.MigrationBatch; }

<div class="row justify-content-center">
<div class="col-md-7">
<div class="card">
    <div class="card-header">Import Users — @batch?.BatchName</div>
    <div class="card-body">
        <div class="alert alert-info small">
            CSV format: <code>FullName,WindowsUsername,ComputerName,OldEmail,NewEmail,TargetMailbox,Status</code><br>
            <a asp-action="DownloadTemplate" class="fw-semibold">Download template CSV</a>
        </div>
        <form asp-action="ImportCsv" asp-route-batchId="@batch?.BatchId" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label fw-semibold">Select CSV File</label>
                <input type="file" name="file" accept=".csv" class="form-control" required />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Import</button>
                <a asp-action="Index" asp-route-batchId="@batch?.BatchId" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
</div>
</div>
