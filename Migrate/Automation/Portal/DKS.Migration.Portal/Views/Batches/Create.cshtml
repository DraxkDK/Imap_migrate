@model DKS.Migration.Portal.Models.MigrationBatch
@{ ViewData["Title"] = "Create Migration Batch"; }

<div class="row justify-content-center">
<div class="col-lg-8">
<div class="card">
    <div class="card-header">Create Migration Batch</div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="BatchName" class="form-label fw-semibold">Batch Name</label>
                    <input asp-for="BatchName" class="form-control" placeholder="ABC Migration 2026-06" />
                </div>
                <div class="col-md-4">
                    <label asp-for="CustomerId" class="form-label fw-semibold">Customer</label>
                    <select asp-for="CustomerId" asp-items="ViewBag.Customers" class="form-select">
                        <option value="">-- Select --</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="SourceType" class="form-label fw-semibold">Source Mail Type</label>
                    <select asp-for="SourceType" asp-items="Html.GetEnumSelectList<DKS.Migration.Portal.Models.SourceMailType>()" class="form-select"></select>
                </div>
                <div class="col-md-4">
                    <label asp-for="DestinationType" class="form-label fw-semibold">Destination Type</label>
                    <select asp-for="DestinationType" asp-items="Html.GetEnumSelectList<DKS.Migration.Portal.Models.DestinationType>()" class="form-select"></select>
                </div>
                <div class="col-md-4">
                    <label asp-for="Mode" class="form-label fw-semibold">Agent Mode</label>
                    <select asp-for="Mode" asp-items="Html.GetEnumSelectList<DKS.Migration.Portal.Models.AgentMode>()" class="form-select"></select>
                </div>
                <div class="col-12">
                    <label asp-for="BackupPstPath" class="form-label fw-semibold">Backup PST Path</label>
                    <input asp-for="BackupPstPath" class="form-control" placeholder="\\NAS\PST-Migration\ABC" />
                </div>
                <div class="col-md-6">
                    <label asp-for="CutoverTime" class="form-label fw-semibold">Cutover Time</label>
                    <input asp-for="CutoverTime" type="datetime-local" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="ImportTargetFolder" class="form-label fw-semibold">Import Target Folder</label>
                    <input asp-for="ImportTargetFolder" class="form-control" placeholder="/Imported POP3" />
                </div>
                <div class="col-md-4">
                    <div class="form-check form-switch mt-4">
                        <input asp-for="RequireUserLogin" class="form-check-input" type="checkbox" />
                        <label asp-for="RequireUserLogin" class="form-check-label">Require User Login</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-check form-switch mt-4">
                        <input asp-for="CloseOutlookAutomatically" class="form-check-input" type="checkbox" />
                        <label asp-for="CloseOutlookAutomatically" class="form-check-label">Close Outlook Auto</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-check form-switch mt-4">
                        <input asp-for="RollbackEnabled" class="form-check-input" type="checkbox" />
                        <label asp-for="RollbackEnabled" class="form-check-label">Rollback Enabled</label>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Create Batch</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
</div>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
