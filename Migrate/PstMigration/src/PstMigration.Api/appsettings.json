{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=pstmigration.db"
  },
  "Agent": {
    "RegistrationToken": "CHANGE_ME_dev_registration_token",
    "HeartbeatIntervalSeconds": 30,
    "MaxConcurrentRequestsPerMailbox": 2,
    "ScanIntervalMinutes": 60,
    "DefaultPstFolders": [ "C:\\ProgramData\\DKS\\PST" ]
  },
  "DefaultTenant": {
    "Name": "Default Tenant",
    "Domain": "contoso.onmicrosoft.com",
    "EntraTenantId": "00000000-0000-0000-0000-000000000000",
    "ClientId": "00000000-0000-0000-0000-000000000000",
    "CertThumbprint": "",
    "CertLocation": "store:CurrentUser/My"
  }
}
