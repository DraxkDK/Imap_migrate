@page
@model ReportsModel
@{
    ViewData["Title"] = "Reports";
}

<h1 class="h3 mb-3">Migration Reports</h1>
<p class="text-muted small">CSV exports redact all message bodies and attachment content.</p>

<table class="table table-sm table-hover">
    <thead>
        <tr><th>Job</th><th>Status</th><th>Started</th><th>Completed</th><th>Export</th></tr>
    </thead>
    <tbody>
    @foreach (var j in Model.Jobs)
    {
        <tr>
            <td>@j.Name</td>
            <td><span class="badge bg-secondary">@j.Status</span></td>
            <td class="small">@j.StartedAt?.ToString("yyyy-MM-dd HH:mm")</td>
            <td class="small">@j.CompletedAt?.ToString("yyyy-MM-dd HH:mm")</td>
            <td>
                <a class="btn btn-xs btn-outline-secondary" asp-page-handler="SummaryCsv" asp-route-jobId="@j.Id">Summary</a>
                <a class="btn btn-xs btn-outline-secondary" asp-page-handler="ItemsCsv" asp-route-jobId="@j.Id">Items</a>
            </td>
        </tr>
    }
    @if (Model.Jobs.Count == 0)
    {
        <tr><td colspan="5" class="text-center text-muted py-4">No jobs yet.</td></tr>
    }
    </tbody>
</table>
